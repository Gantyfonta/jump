{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A high score entry for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "time": { "type": "number", "description": "Time in milliseconds" },
        "formattedTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "time", "createdAt"]
    }
  },
  "firestore": {
    "/highscores/{scoreId}": {
      "schema": "Score",
      "description": "Collection of speedrun high scores"
    }
  }
}
