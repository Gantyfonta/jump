rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Highscores collection
    match /highscores/{scoreId} {
      // Anyone can read highscores to see the leaderboard
      // Use list to allow queries for top scores
      allow list: if true;
      allow get: if true;

      // Creating a score
      // - Must be signed in
      // - Must set their own userId
      // - time must be a positive number
      // - createdAt must be server time
      allow create: if isSignedIn() 
        && isValidId(scoreId)
        && incoming().userId == request.auth.uid
        && incoming().time is number && incoming().time > 0
        && incoming().userName is string && incoming().userName.size() > 0 && incoming().userName.size() <= 20
        && incoming().createdAt == request.time;

      // Highscores are immutable (once submitted, cannot be changed)
      allow update, delete: if false;
    }
  }
}
